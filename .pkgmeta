package-as: M33kAuras

externals:
  M33kAuras/Libs/LibStub: https://repos.curseforge.com/wow/libstub/trunk
  M33kAuras/Libs/CallbackHandler-1.0: https://repos.curseforge.com/wow/callbackhandler/trunk/CallbackHandler-1.0
  M33kAuras/Libs/AceTimer-3.0: https://repos.curseforge.com/wow/ace3/trunk/AceTimer-3.0
  M33kAuras/Libs/AceSerializer-3.0: https://repos.curseforge.com/wow/ace3/trunk/AceSerializer-3.0
  M33kAuras/Libs/AceComm-3.0: https://repos.curseforge.com/wow/ace3/trunk/AceComm-3.0
  M33kAuras/Libs/Chomp: https://github.com/wow-rp-addons/Chomp.git
  M33kAuras/Libs/LibSharedMedia-3.0: https://repos.curseforge.com/wow/libsharedmedia-3-0/trunk/LibSharedMedia-3.0
  M33kAuras/Libs/LibDataBroker-1.1: https://github.com/tekkub/libdatabroker-1-1
  M33kAuras/Libs/LibCompress: https://repos.curseforge.com/wow/libcompress/trunk
  M33kAuras/Libs/LibDeflate: https://github.com/SafeteeWoW/LibDeflate
  M33kAuras/Libs/LibSpellRange-1.0: https://github.com/ascott18/LibSpellRange-1.0
  M33kAuras/Libs/LibRangeCheck-3.0: https://github.com/WeakAuras/LibRangeCheck-3.0/
  M33kAuras/Libs/LibCustomGlow-1.0: https://github.com/Stanzilla/LibCustomGlow
  M33kAuras/Libs/LibDBIcon-1.0: https://repos.curseforge.com/wow/libdbicon-1-0/trunk/LibDBIcon-1.0
  M33kAuras/Libs/LibGetFrame-1.0: https://github.com/mrbuds/LibGetFrame
  M33kAuras/Libs/Archivist:
    url: https://github.com/emptyrivers/Archivist
    tag: v1.0.8
  M33kAuras/Libs/LibSerialize:
    url: https://github.com/rossnichols/LibSerialize
    tag: v1.0.0
  M33kAuras/Libs/LibSpecialization:
    url: https://github.com/BigWigsMods/LibSpecialization.git/LibSpecialization
  M33kAuras/Libs/TaintLess:
    url: https://www.townlong-yak.com/addons.git/taintless
    commit: default
  M33kAurasOptions/Libs/AceConfig-3.0: https://repos.curseforge.com/wow/ace3/trunk/AceConfig-3.0
  M33kAurasOptions/Libs/AceGUI-3.0: https://repos.curseforge.com/wow/ace3/trunk/AceGUI-3.0
  M33kAurasOptions/Libs/AceGUI-3.0-SharedMediaWidgets: https://repos.curseforge.com/wow/ace-gui-3-0-shared-media-widgets/trunk/AceGUI-3.0-SharedMediaWidgets
  M33kAurasOptions/Libs/LibUIDropDownMenu: https://repos.wowace.com/wow/libuidropdownmenu/trunk/LibUIDropDownMenu
  M33kAurasOptions/Libs/LibAPIAutoComplete-1.0: https://github.com/WeakAuras/LibAPIAutoComplete-1.0/

enable-nolib-creation: no

manual-changelog:
  filename: CHANGELOG.md
  markup-type: markdown

ignore:
  - README.md
  - CONTRIBUTING.md
  - babelfish.lua
  - update_translations.sh
  - generate_changelog.sh
  - M33kAuras/Libs/LibDeflate/docs
  - M33kAuras/Libs/LibDeflate/examples
  - M33kAuras/Libs/LibDeflate/*.md

plain-copy:
  - M33kAurasModelPaths/*.lua

move-folders:
  M33kAuras/M33kAuras: M33kAuras
  M33kAuras/M33kAurasOptions: M33kAurasOptions
  M33kAuras/M33kAurasModelPaths: M33kAurasModelPaths
  M33kAuras/M33kAurasTemplates: M33kAurasTemplates
  M33kAuras/M33kAurasArchive: M33kAurasArchive
  M33kAuras/Libs/LibRangeCheck-3.0/LibRangeCheck-3.0: M33kAuras/Libs/LibRangeCheck-3.0
  M33kAurasOptions/Libs/LibAPIAutoComplete-1.0/LibAPIAutoComplete-1.0: M33kAurasOptions/Libs/LibAPIAutoComplete-1.0
  M33kAuras/WeakAuras: WeakAuras
  M33kAuras/M33Auras: M33Auras
