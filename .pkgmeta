package-as: M33Auras

externals:
  M33Auras/Libs/LibStub: https://repos.curseforge.com/wow/libstub/trunk
  M33Auras/Libs/CallbackHandler-1.0: https://repos.curseforge.com/wow/callbackhandler/trunk/CallbackHandler-1.0
  M33Auras/Libs/AceTimer-3.0: https://repos.curseforge.com/wow/ace3/trunk/AceTimer-3.0
  M33Auras/Libs/AceSerializer-3.0: https://repos.curseforge.com/wow/ace3/trunk/AceSerializer-3.0
  M33Auras/Libs/AceComm-3.0: https://repos.curseforge.com/wow/ace3/trunk/AceComm-3.0
  M33Auras/Libs/Chomp: https://github.com/wow-rp-addons/Chomp.git
  M33Auras/Libs/LibSharedMedia-3.0: https://repos.curseforge.com/wow/libsharedmedia-3-0/trunk/LibSharedMedia-3.0
  M33Auras/Libs/LibDataBroker-1.1: https://github.com/tekkub/libdatabroker-1-1
  M33Auras/Libs/LibCompress: https://repos.curseforge.com/wow/libcompress/trunk
  M33Auras/Libs/LibDeflate: https://github.com/SafeteeWoW/LibDeflate
  M33Auras/Libs/LibSpellRange-1.0: https://github.com/ascott18/LibSpellRange-1.0
  M33Auras/Libs/LibRangeCheck-3.0: https://github.com/WeakAuras/LibRangeCheck-3.0/
  M33Auras/Libs/LibCustomGlow-1.0: https://github.com/Stanzilla/LibCustomGlow
  M33Auras/Libs/LibDBIcon-1.0: https://repos.curseforge.com/wow/libdbicon-1-0/trunk/LibDBIcon-1.0
  M33Auras/Libs/LibGetFrame-1.0: https://github.com/mrbuds/LibGetFrame
  M33Auras/Libs/Archivist:
    url: https://github.com/emptyrivers/Archivist
    tag: v1.0.8
  M33Auras/Libs/LibSerialize:
    url: https://github.com/rossnichols/LibSerialize
    tag: v1.0.0
  M33Auras/Libs/LibSpecialization:
    url: https://github.com/BigWigsMods/LibSpecialization.git/LibSpecialization
  M33Auras/Libs/TaintLess:
    url: https://www.townlong-yak.com/addons.git/taintless
    commit: default
  M33AurasOptions/Libs/AceConfig-3.0: https://repos.curseforge.com/wow/ace3/trunk/AceConfig-3.0
  M33AurasOptions/Libs/AceGUI-3.0: https://repos.curseforge.com/wow/ace3/trunk/AceGUI-3.0
  M33AurasOptions/Libs/AceGUI-3.0-SharedMediaWidgets: https://repos.curseforge.com/wow/ace-gui-3-0-shared-media-widgets/trunk/AceGUI-3.0-SharedMediaWidgets
  M33AurasOptions/Libs/LibUIDropDownMenu: https://repos.wowace.com/wow/libuidropdownmenu/trunk/LibUIDropDownMenu
  M33AurasOptions/Libs/LibAPIAutoComplete-1.0: https://github.com/WeakAuras/LibAPIAutoComplete-1.0/

enable-nolib-creation: no

manual-changelog:
  filename: CHANGELOG.md
  markup-type: markdown

ignore:
  - README.md
  - CONTRIBUTING.md
  - babelfish.lua
  - update_translations.sh
  - generate_changelog.sh
  - M33Auras/Libs/LibDeflate/docs
  - M33Auras/Libs/LibDeflate/examples
  - M33Auras/Libs/LibDeflate/*.md

plain-copy:
  - M33AurasModelPaths/*.lua

move-folders:
  M33Auras/M33Auras: M33Auras
  M33Auras/M33AurasOptions: M33AurasOptions
  M33Auras/M33AurasModelPaths: M33AurasModelPaths
  M33Auras/M33AurasTemplates: M33AurasTemplates
  M33Auras/M33AurasArchive: M33AurasArchive
  M33Auras/Libs/LibRangeCheck-3.0/LibRangeCheck-3.0: M33Auras/Libs/LibRangeCheck-3.0
  M33AurasOptions/Libs/LibAPIAutoComplete-1.0/LibAPIAutoComplete-1.0: M33AurasOptions/Libs/LibAPIAutoComplete-1.0
  M33Auras/WeakAuras: WeakAuras
